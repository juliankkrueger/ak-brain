# PostgreSQL (Railway gibt dir DATABASE_URL automatisch)
DATABASE_URL=postgresql://user:password@host:port/railway

# Session-Sicherheit (zufälliger String, min. 32 Zeichen)
SESSION_SECRET=your-very-long-random-secret-here

# Umgebung
NODE_ENV=production
PORT=3000

# Seed (optional — nur für erstes Setup)
SEED_EMAIL=j.krueger@agenturkrueger-digital.de
SEED_PASSWORD=Krueger2026!
